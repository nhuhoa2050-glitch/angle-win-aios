# ===== ANGLE WIN AIOS — cấu hình =====
# Copy thành .env rồi điền. Bỏ trống cũng chạy được (MOCK mode).

# --- AIOS Hub ---
AIOS_PORT=8800
AIOS_DB=aios.db
AIOS_DASHBOARD=angle-win-aios-v2.html
# Ép chế độ mock (1 = bật). Bỏ trống: tự bật nếu thiếu API key hoặc chưa cài crewai.
AIOS_MOCK=1
# URL hub — crewai & n8n POST angle về đây
AIOS_WEBHOOK_URL=http://localhost:8800

# --- P1 Bảo mật multi-tenant ---
# Token webhook nội bộ: nếu set, n8n/Apify phải gửi header X-AIOS-Token khớp (bỏ trống = tắt, cho dev).
AIOS_TOKEN=
# 1 = chỉ chấp nhận workspace đã đăng ký (ws lạ bị 403). Bỏ trống = dev, tự đăng ký ws mới.
AIOS_STRICT_WS=

# --- Sản phẩm đang chạy ---
PRODUCT_NAME=Sản phẩm demo
PRODUCT_DESCRIPTION=Mô tả ngắn sản phẩm

# --- LLM (để tắt mock, sinh angle thật) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- ChromaDB Pain Bank ---
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=pain_bank

# --- n8n endpoints (workflow tự động) ---
CREWAI_ENDPOINT=http://localhost:8800
# Workspace mà các workflow n8n này phục vụ — gắn vào header X-Workspace-ID
# để dữ liệu tự động vào đúng nhóm. Mỗi nhóm nên có 1 bản workflow với WS_ID riêng.
WS_ID=default
# Phải khớp AIOS_TOKEN của hub (nếu hub bật bảo mật webhook)
AIOS_TOKEN=
TIKTOK_ADS_API_URL=https://business-api.tiktok.com/open_api
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
APIFY_TOKEN=
COMPETITOR_KEYWORDS=

# --- Zalo OA notification ---
ZALO_OA_ACCESS_TOKEN=
ZALO_USER_ID=

# --- Module A: Master Event Logging ---
# Webhook N8N nhận MỌI event (Extract/Generate/Approve/Reject/Test/Win/Flop) để ghi Google Sheets.
# Bỏ trống = tắt forward (vẫn lưu audit nội bộ ở bảng events).
N8N_MASTER_WEBHOOK=
